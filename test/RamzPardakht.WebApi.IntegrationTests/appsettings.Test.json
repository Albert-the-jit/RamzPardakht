{
    "Provider": "Sqlite",
    "Serilog": {
        "MinimumLevel": {
            "Default": "Debug"
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "Sentry"
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithSpan"
        ],
        "Filter": [
            {
                "Name": "ByExcluding",
                "Args": {
                    "expression": "@x is not null and TypeOf(@x) like '%OperationCanceledException%'"
                }
            }
        ]
    },
    "Admin": {
        "Email": "Admin@Admin.com",
        "Password": "123456"
    },
    "LogRequestResponse": {
        "LogMode": "LogAll",
        "ResponseBodyLogMode": "LogAll"
    },
    "HttpLogging": {
        "LoggingFields": "All"
    }
}
